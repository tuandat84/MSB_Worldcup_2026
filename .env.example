# Bắt buộc khi deploy production (đổi chuỗi ngẫu nhiên dài)
JWT_SECRET=change-me-to-a-long-random-string

# Bảo vệ endpoint cron (khuyến nghị khi deploy)
CRON_SECRET=your-random-secret-here

# Railway: mount volume tại /data (đã set trong Dockerfile)
DATA_DIR=/data

# API-Football — nguồn kết quả chính xác hơn ESPN (đăng ký miễn phí tại api-football.com)
API_FOOTBALL_KEY=

# OpenAI — dự đoán AI trên trang chi tiết trận (tùy chọn)
OPENAI_API_KEY=
